{
  "name": "@repo/db",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "bun run generate",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:push": "dotenv -e ../../.env -- prisma db push",
    "push:staging": "dotenv -e ../../.env -e ../../.env.staging -- prisma db push",
    "push:prod": "dotenv -e ../../.env -e ../../.env.prod -- prisma db push",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "dotenv-cli": "^8.0.0",
    "prisma": "^7.5.0",
    "tsx": "^4.19.0",
    "typescript": "5.9.2"
  }
}
