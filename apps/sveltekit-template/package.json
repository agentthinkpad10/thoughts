{
  "name": "sveltekit-template",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- vite dev --port 3001",
    "dev:staging": "dotenv -e ../../.env -e ../../.env.staging -- vite dev --port 3001",
    "dev:prod": "dotenv -e ../../.env -e ../../.env.prod -- vite dev --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "check-types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@repo/api": "*",
    "@repo/svelte-query": "*",
    "@repo/svelte-ui": "*",
    "@tanstack/svelte-query": "^5.75.0",
    "lucide-svelte": "^0.469.0",
    "mode-watcher": "^0.5.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "dotenv-cli": "^8.0.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@sveltejs/adapter-auto": "^6.0.0",
    "@sveltejs/kit": "^2.21.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.1.3",
    "eslint": "^9.39.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.1.3",
    "typescript": "5.9.2",
    "vite": "^6.3.0"
  }
}
