{
  "name": "nextjs-template",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev --port 3000",
    "dev:staging": "dotenv -e ../../.env -e ../../.env.staging -- next dev --port 3000",
    "dev:prod": "dotenv -e ../../.env -e ../../.env.prod -- next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings 0",
    "check-types": "next typegen && tsc --noEmit",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@repo/api": "*",
    "@repo/db": "*",
    "@repo/nextjs-query": "*",
    "@repo/react-ui": "*",
    "@tanstack/react-query": "^5.75.0",
    "@trpc/server": "^11.0.0",
    "@trpc/tanstack-react-query": "^11.0.0",
    "@anthropic-ai/sdk": "^0.39.0",
    "@auth/prisma-adapter": "^2.7.4",
    "date-fns": "^3.0.0",
    "next": "16.2.0",
    "next-auth": "^5.0.0-beta.28",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "lucide-react": "^0.469.0",
    "next-themes": "^0.4.6",
    "superjson": "^2.2.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "@repo/eslint-config": "*",
    "@repo/typescript-config": "*",
    "@tailwindcss/postcss": "^4.1.3",
    "@types/node": "^22.15.3",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@playwright/test": "^1.52.0",
    "eslint": "^9.39.1",
    "tailwindcss": "^4.1.3",
    "typescript": "5.9.2"
  }
}
